# ─────────────────────────────────────────────────────────────────
# .env.example  –  copy to .env for local testing only
# For GitHub Actions: add these as GitHub Secrets (NOT in this file)
# ─────────────────────────────────────────────────────────────────

# Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# YouTube OAuth credentials — from Google Cloud Console
# 1. https://console.cloud.google.com → New Project
# 2. APIs & Services → Enable "YouTube Data API v3"
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#    Type: Desktop App
#    Redirect URI: http://localhost:3000/auth/callback
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...

# YouTube Refresh Token — generated once by running:
#   node scripts/get-refresh-token.js
# This is the most important secret — keep it safe!
YOUTUBE_REFRESH_TOKEN=1//...

# Optional: Lock videos to a specific topic instead of random
# Leave blank to let Claude pick from the built-in topic pool
VIDEO_TOPIC_SEED=
